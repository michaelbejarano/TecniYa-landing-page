---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "TecniYa - Técnicos a domicilio en Perú",
  description = "Encuentra técnicos confiables para reparaciones del hogar de forma rápida y segura."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content="TecniYa - Técnicos a domicilio en Perú" />
    <meta property="og:description" content="Encuentra técnicos confiables para reparaciones del hogar de forma rápida y segura." />
    <meta property="og:type" content="website" />

    <meta name="description" content={description} />
    <meta name="google-site-verification" content="3nvmHlt7H_ht2icTv8q-2BgdtaH9TmTVXLSh4Hz4Bbg" />

   
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --blue:    #1B4FFF;
        --blue-lt: #3D6FFF;
        --orange:  #FF5C1A;
        --bg:      #0A0F1E;
        --bg2:     #0F1628;
        --bg3:     #141C35;
        --muted:   #8892A4;
        --white:   #F8FAFF;
        --border:  rgba(255,255,255,0.07);
        --font-display: 'Syne', sans-serif;
        --font-body:    'Inter', sans-serif;
      }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--white);
        font-family: var(--font-body);
        line-height: 1.6;
        overflow-x: hidden;
      }
      ::selection { background: var(--blue); color: #fff; }
    </style>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6B0SWZW1S8"></script>

    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-6B0SWZW1S8');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>