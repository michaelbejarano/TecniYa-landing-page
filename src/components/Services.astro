---
const services = [
  { icon: "💧", title: "Gasfitería",    subtitle: "Hogar",       desc: "Fugas de agua, tuberías tapadas, instalación de llaves y duchas.", tag: "Urgente",  img: "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=400&q=80" },
  { icon: "⚡", title: "Electricidad",  subtitle: "Hogar",       desc: "Fallas eléctricas, cortocircuitos, instalación de tomacorrientes.", tag: "Popular",  img: "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=400&q=80" },
  { icon: "🪚", title: "Carpintería",   subtitle: "Hogar",       desc: "Armado de muebles, reparación de puertas, instalación de estantes.", tag: "",        img: "https://images.unsplash.com/photo-1504148455328-c376907d081c?w=400&q=80" },
  { icon: "🚿", title: "Duchas",        subtitle: "Instalación", desc: "Mantenimiento, instalación y reparación de duchas eléctricas.", tag: "",           img: "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=400&q=80" },
  { icon: "🔌", title: "Instalaciones", subtitle: "Eléctrica",   desc: "Puntos de luz, cámaras, switches y tableros eléctricos.", tag: "",                  img: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80" },
  { icon: "🏠", title: "Mantenimiento", subtitle: "General",     desc: "Pintura, filtraciones, resanes y reparaciones generales del hogar.", tag: "",        img: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=400&q=80" },
];
---

<section class="services" id="servicios">
  <div class="services-header">
    <span class="section-label">Lo que resolvemos</span>
    <h2>Todos tus problemas del hogar,<br/><em>en un solo lugar</em></h2>
    <p>Desde una fuga a las 2am hasta armar ese mueble pendiente.</p>
  </div>

  <div class="slider">
    <button class="slider--btn slider--btn__prev" aria-label="Anterior">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6" />
      </svg>
    </button>

    <div class="slides__wrapper">
      <div class="slides">
        {services.map((s, i) => (
          <div class="slide" data-index={i} class:list={[{ 'slide--current': i === 0, 'slide--next': i === 1, 'slide--previous': i === services.length - 1 }]}>
            <div class="slide__inner">
              <div class="slide--image__wrapper">
                <img class="slide--image" src={s.img} alt={s.title} loading="lazy" />
                <div class="slide--overlay"></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Background blobs per slide -->
      {services.map((s, i) => (
        <div class="slide__bg" data-index={i} style={`--bg: url(${s.img})`} class:list={[{ 'slide__bg--current': i === 0, 'slide__bg--next': i === 1, 'slide__bg--previous': i === services.length - 1 }]}></div>
      ))}

      <!-- Info overlay -->
      <div class="slides--infos">
        {services.map((s, i) => (
          <div class="slide-info" data-index={i} class:list={[{ 'slide-info--current': i === 0, 'slide-info--next': i === 1, 'slide-info--previous': i === services.length - 1 }]}>
            <div class="slide-info__inner">
              <div class="slide-info--text__wrapper">
                {s.tag && <span class="card-tag">{s.tag}</span>}
                <div data-title class="slide-info--text"><span>{s.icon} {s.title}</span></div>
                <div data-subtitle class="slide-info--text"><span>{s.subtitle}</span></div>
                <div data-description class="slide-info--text"><span>{s.desc}</span></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button class="slider--btn slider--btn__next" aria-label="Siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m9 18 6-6-6-6" />
      </svg>
    </button>
  </div>

  <!-- Dots -->
  <div class="slider-dots">
    {services.map((_, i) => (
      <button class:list={["dot", { "dot--active": i === 0 }]} data-dot={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  /* ---- Section shell ---- */
  .services {
    padding: 7rem 0 5rem;
    overflow: hidden;
    position: relative;
  }
  .services-header {
    max-width: 1100px;
    margin: 0 auto 3.5rem;
    padding: 0 2rem;
    text-align: center;
  }
  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1rem;
  }
  .services-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .services-header h2 em { font-style: normal; color: var(--blue-lt); }
  .services-header p { color: var(--muted); font-size: 1rem; }

  /* ---- Slider layout ---- */
  :root {
    --slide-width: min(22vw, 260px);
    --slide-aspect: 2 / 3;
    --slide-transition: 700ms ease;
  }

  .slider {
    width: 100%;
    max-width: calc(3 * var(--slide-width) + 120px);
    margin: 0 auto;
    height: calc(var(--slide-width) * 1.6);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    position: relative;
  }

  .slider--btn {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s;
    opacity: 0.7;
  }
  .slider--btn svg { stroke: white; width: 20px; height: 20px; }
  .slider--btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); opacity: 1; }

  .slides__wrapper {
    flex: 1;
    height: 100%;
    display: grid;
    place-items: center;
    position: relative;
    & > * { grid-area: 1 / -1; }
  }

  .slides, .slides--infos {
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: grid;
    place-items: center;
    & > * { grid-area: 1 / -1; }
  }

  /* ---- Slides ---- */
  .slide {
    width: var(--slide-width);
    aspect-ratio: var(--slide-aspect);
    perspective: 800px;
    transition: transform var(--slide-transition);
    border-radius: 16px;
    overflow: hidden;
  }

  /* States via JS-toggled classes */
  .slide--current {
    transform: perspective(1000px) translate3d(0, 0, 0) rotateY(0deg) scale(1.18);
    z-index: 20;
    pointer-events: auto;
  }
  .slide--next {
    transform: perspective(1000px) translate3d(calc(var(--slide-width) * 1.08), 0, 0) rotateY(-45deg) scale(1);
    z-index: 10;
  }
  .slide--previous {
    transform: perspective(1000px) translate3d(calc(var(--slide-width) * -1.08), 0, 0) rotateY(45deg) scale(1);
    z-index: 10;
  }
  .slide:not(.slide--current):not(.slide--next):not(.slide--previous) {
    transform: perspective(1000px) translate3d(0, 0, -200px) scale(0.7);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  .slide__inner {
    width: 100%;
    height: 100%;
    border-radius: 16px;
    overflow: hidden;
  }
  .slide--image__wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .slide--image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    transition: filter var(--slide-transition);
  }
  .slide--current .slide--image  { filter: brightness(0.75); }
  .slide--next    .slide--image,
  .slide--previous .slide--image { filter: brightness(0.35) saturate(0.6); }

  .slide--overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,15,30,0.9) 0%, transparent 55%);
    border-radius: 16px;
  }

  /* ---- Background blur ---- */
  .slide__bg {
    position: fixed;
    inset: -20%;
    background-image: var(--bg);
    background-size: cover;
    background-position: center;
    z-index: -1;
    pointer-events: none;
    transition: opacity var(--slide-transition), transform var(--slide-transition);
    opacity: 0;
    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(10,15,30,0.82);
      backdrop-filter: blur(10px);
    }
  }
  .slide__bg--current  { opacity: 1; transform: translateX(0); }
  .slide__bg--previous { opacity: 0; transform: translateX(-8%); }
  .slide__bg--next     { opacity: 0; transform: translateX(8%); }

  /* ---- Slide info text ---- */
  .slide-info {
    width: var(--slide-width);
    aspect-ratio: var(--slide-aspect);
    position: relative;
    z-index: 100;
    pointer-events: none;
  }
  .slide-info__inner { width: 100%; height: 100%; position: relative; }
  .slide-info--text__wrapper {
    position: absolute;
    bottom: 14%;
    left: 0;
    padding: 0 1rem;
    width: 140%;
  }
  .card-tag {
    display: inline-block;
    background: rgba(255,92,26,0.2);
    border: 1px solid rgba(255,92,26,0.4);
    color: var(--orange);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }
  .slide-info--text {
    overflow: hidden;
    & span {
      display: block;
      color: #fff;
      transition: opacity var(--slide-transition), transform var(--slide-transition);
    }
    &[data-title] span  { font-family: var(--font-display); font-size: clamp(1rem, 2.2vw, 1.4rem); font-weight: 800; letter-spacing: -0.03em; }
    &[data-subtitle] span { font-family: var(--font-display); font-size: clamp(0.75rem, 1.4vw, 0.95rem); font-weight: 500; color: var(--muted); margin-left: 0.1rem; }
    &[data-description] span { font-size: clamp(0.65rem, 1.1vw, 0.78rem); color: rgba(255,255,255,0.6); margin-top: 0.3rem; line-height: 1.5; }
  }

  /* text animation */
  .slide-info--current .slide-info--text span {
    opacity: 1;
    transform: translate3d(0,0,0);
    transition-delay: 220ms;
  }
  .slide-info:not(.slide-info--current) .slide-info--text span {
    opacity: 0;
    transform: translate3d(0, 60%, 0);
    transition-delay: 0ms;
  }

  /* ---- Dots ---- */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
  }
  .dot {
    width: 6px; height: 6px;
    border-radius: 100px;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
  }
  .dot--active {
    background: var(--orange);
    width: 22px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    :root { --slide-width: min(42vw, 200px); }
    .slider { height: calc(var(--slide-width) * 1.65); }
  }
  @media (max-width: 480px) {
    :root { --slide-width: 58vw; }
    .slider { height: calc(var(--slide-width) * 1.7); }
    .slide--next, .slide--previous {
      transform: perspective(1000px) translate3d(calc(var(--slide-width) * 0.85), 0, 0) rotateY(-38deg) scale(0.88);
    }
    .slide--previous {
      transform: perspective(1000px) translate3d(calc(var(--slide-width) * -0.85), 0, 0) rotateY(38deg) scale(0.88);
    }
  }
</style>

<script>
  const TOTAL = document.querySelectorAll('.slide').length;

  // state
  let current = 0;

  const slides     = [...document.querySelectorAll('.slide')];
  const slideInfos = [...document.querySelectorAll('.slide-info')];
  const slideBgs   = [...document.querySelectorAll('.slide__bg')];
  const dots       = [...document.querySelectorAll('.dot')];

  const wrap = (n: number, max: number) => ((n % max) + max) % max;

  function getRole(idx: number): 'current' | 'next' | 'previous' | null {
    if (idx === current)                  return 'current';
    if (idx === wrap(current + 1, TOTAL)) return 'next';
    if (idx === wrap(current - 1, TOTAL)) return 'previous';
    return null;
  }

  function applyClasses(el: Element, prefix: string, role: string | null) {
    el.classList.remove(`${prefix}--current`, `${prefix}--next`, `${prefix}--previous`);
    if (role) el.classList.add(`${prefix}--${role}`);
  }

  function render() {
    slides.forEach((el, i)     => applyClasses(el, 'slide',      getRole(i)));
    slideInfos.forEach((el, i) => applyClasses(el, 'slide-info', getRole(i)));
    slideBgs.forEach((el, i)   => applyClasses(el, 'slide__bg',  getRole(i)));
    dots.forEach((el, i) => el.classList.toggle('dot--active', i === current));
  }

  function change(dir: number) {
    current = wrap(current + dir, TOTAL);
    render();
  }

  // Tilt effect
  function initTilt() {
    slides.forEach((slide) => {
      const inner = slide.querySelector('.slide__inner') as HTMLElement;
      if (!inner) return;
      let lerpX = 0, lerpY = 0, targetX = 0, targetY = 0;
      let rafId: number;

      slide.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = slide.getBoundingClientRect();
        const ox = (e.clientX - rect.left - rect.width  / 2) / 8;
        const oy = (e.clientY - rect.top  - rect.height / 2) / 10;
        targetX = ox; targetY = -oy;
      });
      slide.addEventListener('mouseleave', () => { targetX = 0; targetY = 0; });

      function tick() {
        lerpX += (targetX - lerpX) * 0.1;
        lerpY += (targetY - lerpY) * 0.1;
        inner.style.transform = `rotateY(${lerpX.toFixed(2)}deg) rotateX(${lerpY.toFixed(2)}deg)`;
        rafId = requestAnimationFrame(tick);
      }
      tick();
    });
  }

  // Buttons
  document.querySelector('.slider--btn__prev')?.addEventListener('click', () => change(-1));
  document.querySelector('.slider--btn__next')?.addEventListener('click', () => change(1));

  // Dot clicks
  dots.forEach((dot, i) => dot.addEventListener('click', () => { current = i; render(); }));

  // Touch / swipe
  let touchStartX = 0;
  const wrapper = document.querySelector('.slides__wrapper')!;
  wrapper.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  wrapper.addEventListener('touchend',   (e: TouchEvent) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) change(diff > 0 ? 1 : -1);
  });

  render();
  initTilt();
</script>