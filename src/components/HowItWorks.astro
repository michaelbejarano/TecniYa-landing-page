---
const steps = [
  { num: "01", icon: "📱", title: "Describe tu problema",   desc: "Abre la app, selecciona el tipo de servicio y cuéntanos qué ocurre. Tardas menos de 30 segundos." },
  { num: "02", icon: "📍", title: "Vemos técnicos cercanos", desc: "El sistema detecta tu ubicación y muestra técnicos disponibles en tiempo real con sus calificaciones y precios." },
  { num: "03", icon: "⚖️", title: "Compara y elige",         desc: "Revisa cotizaciones, perfiles y reseñas. Tú decides a quién contratar, sin presiones." },
  { num: "04", icon: "✅", title: "Problema resuelto",        desc: "El técnico llega, resuelve y pagas desde la app. Califica el servicio para ayudar a la comunidad." },
];
---
<section class="how" id="como-funciona">
  <div class="how-inner">
    <div class="section-header">
      <span class="section-label">El proceso</span>
      <h2>De la emergencia a la solución<br/><em>en 4 pasos</em></h2>
    </div>
    <div class="steps-grid">
      {steps.map((step) => (
        <div class="step-card">
          <div class="step-num">{step.num}</div>
          <div class="step-icon">{step.icon}</div>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how {
    padding: 7rem 0;
    background: var(--bg2);
    position: relative;
    overflow: hidden;
  }
  .how::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse, rgba(27,79,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .how-inner { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.15;
  }
  .section-header h2 em { font-style: normal; color: var(--blue-lt); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .step-card {
    padding: 2rem 1.75rem;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.2s;
  }
  .step-card:hover { border-color: rgba(27,79,255,0.35); }
  .step-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(27,79,255,0.2);
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .step-icon { font-size: 2rem; margin-bottom: 1rem; line-height: 1; }
  .step-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .step-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.65; }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .steps-grid { grid-template-columns: 1fr; } }
</style>