<section class="hero" id="inicio">

  <!-- Fondo: foto técnico con overlay oscuro -->
  <div class="hero-bg" aria-hidden="true">
    <!-- 
      CAMBIA ESTA URL por tu foto: /tecnico-hero.jpg
      Mientras tanto usa esta imagen de Unsplash de técnico con herramientas
    -->
    <img src="images/fondo.jpg" alt="" />
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="hero-inner">

    <!-- Columna izquierda: texto -->
    <div class="hero-content">
      <span class="eyebrow">🔧 Disponible en tu ciudad</span>
      <h1>¿Tuviste un problema<br/> y no supiste<br/><em>a quién llamar?</em></h1>
      <p class="hero-sub">
        TecniYa conecta tu emergencia en el hogar con técnicos certificados y cercanos — en minutos, no en días.
      </p>
      <div class="hero-actions">
        <a href="#contacto" class="btn-primary">Únete antes del lanzamiento</a>
        <a href="#servicios" class="btn-ghost">Ver servicios →</a>
      </div>
      <div class="hero-trust">
        <div class="trust-pill">⚡ Respuesta en &lt; 15 min</div>
        <div class="trust-pill">⭐ Técnicos verificados</div>
        <div class="trust-pill">📍 Geolocalización en tiempo real</div>
      </div>
    </div>

    <!-- Columna derecha: mockup celular + dots -->
    <div class="hero-visual" aria-hidden="true">

      <!-- Dots flotantes de técnicos — van ENCIMA del celular -->
      <div class="tech-dot dot-a"><span class="dot-icon">🔧</span><span class="dot-tag">Gasfitero · 0.8km</span></div>
      <div class="tech-dot dot-b"><span class="dot-icon">⚡</span><span class="dot-tag">Electricista · 1.2km</span></div>
      <div class="tech-dot dot-c"><span class="dot-icon">🪚</span><span class="dot-tag">Carpintero · 2.1km</span></div>
      <div class="tech-dot dot-d"><span class="dot-icon">✅</span><span class="dot-tag">En camino · 3 min</span></div>

      <!-- Mockup celular SVG (frame) + pantalla interna -->
      <div class="phone-mockup">
        <div class="phone-frame">
          <!-- Notch -->
          <div class="phone-notch"></div>
          <!-- Pantalla: app TecniYa -->
          <div class="phone-screen">
            <div class="app-bar">
              <span class="app-logo">TecniYa</span>
              <span class="app-status">● En línea</span>
            </div>
            <div class="app-map-area">
              <!-- Mini mapa con rings -->
              <div class="mini-grid"></div>
              <div class="mini-ring r1"></div>
              <div class="mini-ring r2"></div>
              <div class="mini-pin">📍</div>
              <div class="mini-tech t1">🔧</div>
              <div class="mini-tech t2">⚡</div>
              <div class="mini-tech t3">🪚</div>
            </div>
            <div class="app-bottom">
              <p class="app-label">3 técnicos disponibles</p>
              <div class="app-techs">
                <div class="app-tech-card">
                  <span class="tc-icon">🔧</span>
                  <div>
                    <p class="tc-name">Carlos R.</p>
                    <p class="tc-dist">0.8km · ⭐4.9</p>
                  </div>
                  <span class="tc-btn">Ver</span>
                </div>
                <div class="app-tech-card">
                  <span class="tc-icon">⚡</span>
                  <div>
                    <p class="tc-name">Miguel T.</p>
                    <p class="tc-dist">1.2km · ⭐4.8</p>
                  </div>
                  <span class="tc-btn">Ver</span>
                </div>
              </div>
            </div>
          </div>
          <!-- Botón home -->
          <div class="phone-home"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ---- Hero shell ---- */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 7rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  /* ---- Fondo foto ---- */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    /* degradado: muy oscuro a la izquierda (texto legible), semitransparente a la derecha */
    background:
      linear-gradient(
        to right,
        rgba(10,15,30,0.97) 0%,
        rgba(10,15,30,0.88) 45%,
        rgba(10,15,30,0.55) 70%,
        rgba(10,15,30,0.35) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(10,15,30,0.4) 0%,
        transparent 40%,
        transparent 60%,
        rgba(10,15,30,0.6) 100%
      );
  }

  /* ---- Layout ---- */
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  /* ---- Texto ---- */
  .eyebrow {
    display: inline-block;
    background: rgba(27,79,255,0.15);
    border: 1px solid rgba(27,79,255,0.4);
    color: #7B9FFF;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 1.5rem;
  }
  h1 em { font-style: normal; color: var(--orange); }
  .hero-sub {
    font-size: 1.05rem;
    color: rgba(248,250,255,0.8);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .btn-primary {
    background: var(--orange);
    color: #fff;
    padding: 0.875rem 1.75rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.975rem;
    transition: transform 0.2s, opacity 0.2s;
    box-shadow: 0 4px 24px rgba(255,92,26,0.4);
  }
  .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }
  .btn-ghost {
    color: var(--white);
    padding: 0.875rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.975rem;
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(4px);
    background: rgba(255,255,255,0.06);
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.1); }
  .hero-trust { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .trust-pill {
    font-size: 0.78rem;
    color: rgba(248,250,255,0.7);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(6px);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
  }

  /* ---- Visual column ---- */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 520px;
  }

  /* ---- Tech dots flotantes ---- */
  .tech-dot {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    z-index: 10;
    animation: dot-appear 0.6s ease both, dot-float 4s ease-in-out infinite;
  }
  .tech-dot .dot-icon {
    background: rgba(10,15,30,0.85);
    border: 2px solid var(--orange);
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    box-shadow: 0 0 14px rgba(255,92,26,0.4);
    backdrop-filter: blur(6px);
    flex-shrink: 0;
  }
  .tech-dot .dot-tag {
    background: rgba(10,15,30,0.8);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--white);
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
    backdrop-filter: blur(6px);
  }
  .dot-a { top: 6%;  left: -2%;  animation-delay: 0.3s; }
  .dot-b { top: 16%; right: -4%; animation-delay: 0.9s; }
  .dot-c { bottom: 22%; left: -4%; animation-delay: 1.5s; }
  .dot-d { bottom: 10%; right: 2%; animation-delay: 2.1s; }

  @keyframes dot-appear {
    from { opacity: 0; transform: scale(0.7); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes dot-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-7px); }
  }

  /* ---- Phone mockup ---- */
  .phone-mockup {
    position: relative;
    z-index: 5;
    filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)) drop-shadow(0 0 40px rgba(27,79,255,0.15));
  }
  .phone-frame {
    width: 240px;
    background: #0d1117;
    border-radius: 36px;
    border: 2px solid rgba(255,255,255,0.12);
    padding: 14px 8px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    position: relative;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.05),
      0 0 0 6px rgba(255,255,255,0.03);
  }
  .phone-notch {
    width: 70px; height: 20px;
    background: #0d1117;
    border-radius: 0 0 14px 14px;
    margin-bottom: 8px;
    border: 2px solid rgba(255,255,255,0.08);
    border-top: none;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .phone-screen {
    width: 100%;
    background: var(--bg);
    border-radius: 20px;
    overflow: hidden;
    flex: 1;
  }
  .phone-home {
    width: 70px; height: 4px;
    background: rgba(255,255,255,0.2);
    border-radius: 10px;
    margin-top: 12px;
  }

  /* ---- App UI inside screen ---- */
  .app-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 12px 8px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
  }
  .app-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.85rem;
    color: var(--white);
  }
  .app-status {
    font-size: 0.6rem;
    color: #4ade80;
    font-weight: 600;
  }

  /* Mini mapa */
  .app-map-area {
    height: 160px;
    position: relative;
    background: #080d1a;
    overflow: hidden;
  }
  .mini-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(27,79,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(27,79,255,0.08) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .mini-ring {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1px solid rgba(27,79,255,0.25);
    transform: translate(-50%,-50%);
    animation: pulse-ring 3s ease-out infinite;
  }
  .r1 { width: 40px;  height: 40px;  animation-delay: 0s; }
  .r2 { width: 80px;  height: 80px;  animation-delay: 0.9s; }
  @keyframes pulse-ring {
    0%   { opacity: 0.7; }
    100% { opacity: 0; transform: translate(-50%,-50%) scale(1.15); }
  }
  .mini-pin {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    font-size: 1.1rem;
    z-index: 5;
    filter: drop-shadow(0 0 6px rgba(27,79,255,0.8));
  }
  .mini-tech {
    position: absolute;
    font-size: 0.85rem;
    background: rgba(10,15,30,0.8);
    border: 1px solid var(--orange);
    border-radius: 50%;
    width: 26px; height: 26px;
    display: flex; align-items: center; justify-content: center;
    animation: dot-float 4s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(255,92,26,0.3);
  }
  .t1 { top: 20%; left: 65%; animation-delay: 0.4s; }
  .t2 { top: 60%; left: 20%; animation-delay: 1.1s; }
  .t3 { top: 30%; left: 30%; animation-delay: 1.8s; }

  /* Bottom cards */
  .app-bottom { padding: 8px 10px 10px; }
  .app-label {
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .app-techs { display: flex; flex-direction: column; gap: 5px; }
  .app-tech-card {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 8px;
  }
  .tc-icon { font-size: 1rem; flex-shrink: 0; }
  .tc-name { font-size: 0.65rem; font-weight: 600; color: var(--white); line-height: 1.2; }
  .tc-dist { font-size: 0.58rem; color: var(--muted); }
  .tc-btn {
    margin-left: auto;
    background: var(--orange);
    color: #fff;
    font-size: 0.58rem;
    font-weight: 700;
    padding: 3px 7px;
    border-radius: 5px;
    flex-shrink: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-visual { height: 380px; }
    .phone-frame { width: 200px; }
    .app-map-area { height: 120px; }
    .dot-a { top: 2%;   left: 2%; }
    .dot-b { top: 10%;  right: 2%; }
    .dot-c { bottom: 28%; left: 2%; }
    .dot-d { bottom: 14%; right: 2%; }
    .hero-bg-overlay {
      background: linear-gradient(
        to bottom,
        rgba(10,15,30,0.95) 0%,
        rgba(10,15,30,0.85) 50%,
        rgba(10,15,30,0.75) 100%
      );
    }
  }
</style>